{
  "author": "Apache Software Foundation",
  "name": "plugman",
  "description": "install/uninstall Cordova plugins",
  "version": "4.0.0-dev",
  "repository": "github:apache/cordova-plugman",
  "bugs": "https://github.com/apache/cordova-plugman/issues",
  "main": "plugman.js",
  "engines": {
    "node": ">=20.17.0 || >=22.9.0"
  },
  "dependencies": {
    "cordova-lib": "^13.0.0",
    "loud-rejection": "^2.2.0",
    "nopt": "^9.0.0",
    "p-each-series": "^2.2.0",
    "p-try": "^2.2.0"
  },
  "devDependencies": {
    "@cordova/eslint-config": "^6.0.1",
    "jasmine": "^6.3.0",
    "nyc": "^18.0.0",
    "rewire": "^9.0.1"
  },
  "bin": {
    "plugman": "./bin.js"
  },
  "scripts": {
    "test": "npm run lint && npm run test:coverage",
    "test:coverage": "nyc jasmine",
    "lint": "eslint ."
  },
  "license": "Apache-2.0",
  "nyc": {
    "all": true,
    "exclude": [
      "bin.js",
      "coverage/",
      "spec/"
    ],
    "reporter": [
      "lcov",
      "text"
    ]
  }
}
